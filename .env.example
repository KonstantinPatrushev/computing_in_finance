# Copy this file to .env and fill in your tokens.
# Never commit .env — it is in .gitignore.

# IBM Quantum Platform token
# Sign up at: https://quantum.ibm.com/
# Find token at: https://quantum.ibm.com/account
IBM_QUANTUM_TOKEN=

# IBM Quantum CRN (instance identifier on IBM Cloud), if using new IBM Cloud auth
IBM_QUANTUM_INSTANCE=

# D-Wave Leap API token
# Sign up at: https://cloud.dwavesys.com/leap/signup/
# Find token at: https://cloud.dwavesys.com/leap/
DWAVE_API_TOKEN=

# Optional: D-Wave Leap solver endpoint (usually not needed)
DWAVE_API_ENDPOINT=https://cloud.dwavesys.com/sapi/

# Bauman Octillion API token (MGTU + VNIIA + Rosatom, octillion.bmstu.ru)
# Sign up at: https://octillion.bmstu.ru/
# Request a token in your personal account.
BAUMAN_OCTILLION_TOKEN=

# Optional: Bauman Octillion API endpoint (usually not needed)
BAUMAN_OCTILLION_ENDPOINT=https://octillion.bmstu.ru/

# Random seed used as the global default for all stochastic operations
CIF_DEFAULT_SEED=42
